---
const base = import.meta.env.BASE_URL;
---

<header>
  <nav class="flex items-center justify-between px-5 py-5 md:px-20 md:py-6">
    <a href={base} class="font-sora text-[28px] font-semibold text-black leading-none">
      abel.
    </a>

    <!-- Hamburger (mobile only) -->
    <button id="menu-toggle" class="md:hidden flex flex-col gap-[5px] p-1" aria-label="Toggle menu">
      <span class="block w-6 h-0.5 bg-black transition-all"></span>
      <span class="block w-6 h-0.5 bg-black transition-all"></span>
      <span class="block w-6 h-0.5 bg-black transition-all"></span>
    </button>

    <!-- Desktop links -->
    <div class="hidden md:flex items-center gap-10">
      <a href={base} class="flex items-center gap-1.5">
        <span class="font-dm text-[11px] text-[#AAAAAA]">01</span>
        <span class="font-dm text-sm text-black">Home</span>
      </a>
      <a href={`${base}articles`} class="flex items-center gap-1.5">
        <span class="font-dm text-[11px] text-[#AAAAAA]">02</span>
        <span class="font-dm text-sm text-black">Articles</span>
      </a>
      <a href={`${base}#projects`} class="flex items-center gap-1.5">
        <span class="font-dm text-[11px] text-[#AAAAAA]">03</span>
        <span class="font-dm text-sm text-black">Projects</span>
      </a>
      <a href={`${base}#contact`} class="flex items-center gap-1.5">
        <span class="font-dm text-[11px] text-[#AAAAAA]">04</span>
        <span class="font-dm text-sm text-black">Contact</span>
      </a>
    </div>
  </nav>

  <!-- Mobile dropdown -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-[#F0F0F0] px-5 py-5 flex flex-col gap-5">
    <a href={base} class="flex items-center gap-2">
      <span class="font-dm text-[11px] text-[#AAAAAA]">01</span>
      <span class="font-dm text-sm text-black">Home</span>
    </a>
    <a href={`${base}articles`} class="flex items-center gap-2">
      <span class="font-dm text-[11px] text-[#AAAAAA]">02</span>
      <span class="font-dm text-sm text-black">Articles</span>
    </a>
    <a href={`${base}#projects`} class="flex items-center gap-2">
      <span class="font-dm text-[11px] text-[#AAAAAA]">03</span>
      <span class="font-dm text-sm text-black">Projects</span>
    </a>
    <a href={`${base}#contact`} class="flex items-center gap-2">
      <span class="font-dm text-[11px] text-[#AAAAAA]">04</span>
      <span class="font-dm text-sm text-black">Contact</span>
    </a>
  </div>

  <div class="h-px bg-[#F0F0F0]"></div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>
