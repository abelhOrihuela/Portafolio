---
const base = import.meta.env.BASE_URL;
---

<footer class="bg-black px-20 py-12 flex flex-col gap-12">
  <div class="flex justify-between items-start">
    <div class="flex flex-col gap-3">
      <a href={base} class="font-sora text-[28px] font-semibold text-white leading-none">
        abel.
      </a>
      <span class="font-dm text-sm text-[#666666]">Software engineer, maker, writer.</span>
    </div>
    <div class="flex items-center gap-8">
      <a
        href="https://github.com/abelhOrihuela"
        target="_blank"
        rel="noopener noreferrer"
        class="font-dm text-sm text-white hover:text-[#AAAAAA] transition-colors"
      >GitHub</a>
      <a
        href="https://linkedin.com/in/abelorihuela"
        target="_blank"
        rel="noopener noreferrer"
        class="font-dm text-sm text-white hover:text-[#AAAAAA] transition-colors"
      >LinkedIn</a>
      <a
        href="https://x.com/abelorihuela"
        target="_blank"
        rel="noopener noreferrer"
        class="font-dm text-sm text-white hover:text-[#AAAAAA] transition-colors"
      >Twitter / X</a>
      <a
        href="mailto:hello@abelorihuela.dev"
        class="font-dm text-sm text-white hover:text-[#AAAAAA] transition-colors"
      >Email</a>
    </div>
  </div>
  <div class="h-px bg-[#222222]"></div>
  <div class="flex justify-between items-center">
    <span class="font-dm text-xs text-[#666666]">
      © 2026 Abel Orihuela Mendoza. All rights reserved.
    </span>
    <span class="font-sora text-[13px] text-[#666666]">Designed with intention.</span>
  </div>
</footer>
