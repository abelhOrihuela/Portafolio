---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles');
const latestArticles = articles
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const base = import.meta.env.BASE_URL;

function toSlug(id: string) {
  return id.replace(/\.(md|mdx)$/, '');
}

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
---

<Layout>
  <Nav />

  <!-- Hero -->
  <section class="px-20 py-[100px] flex gap-20 items-center">
    <div class="flex-1 flex flex-col gap-8">
      <span class="font-dm text-[11px] font-medium text-[#AAAAAA] tracking-[4px] uppercase">
        Software Engineer
      </span>
      <h1 class="font-sora text-[72px] font-bold leading-[1.05] text-black w-[580px]">
        Abel<br />Orihuela<br />Mendoza.
      </h1>
      <p class="font-dm text-base leading-[1.7] text-[#666666] w-[520px]">
        Software engineer with 7+ years of experience building web applications across fintech,
        wellness, bioinformatics, ecommerce and data analysis. Proficient in Python, JavaScript,
        functional programming, DevOps and product building.
      </p>
      <div class="flex items-center gap-4">
        <a
          href="#contact"
          class="bg-black text-white font-dm text-sm font-medium px-8 py-3.5 inline-block"
        >
          Get in touch
        </a>
        <a
          href={`${base}articles`}
          class="border border-black text-black font-dm text-sm font-medium px-8 py-3.5 inline-block"
        >
          Read articles
        </a>
      </div>
    </div>
    <div class="flex-shrink-0">
      <img
        src={`${base}abel.jpeg`}
        alt="Abel Orihuela Mendoza"
        class="w-[420px] h-[520px] object-cover"
      />
    </div>
  </section>

  <div class="h-px bg-[#F0F0F0]"></div>

  <!-- Topics -->
  <section class="bg-[#F5F5F5] p-20 flex flex-col gap-12">
    <div class="flex items-end justify-between w-full">
      <h2 class="font-sora text-5xl font-semibold text-black">Topics</h2>
      <span class="font-dm text-sm text-[#888888]">What I write &amp; build about</span>
    </div>
    <div class="grid grid-cols-3 gap-5 w-full">
      <!-- Software Development -->
      <div class="flex flex-col justify-between p-7 h-[200px] bg-white border border-[#F0F0F0]">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="28"
          height="28"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="4 17 10 11 4 5"></polyline>
          <line x1="12" y1="19" x2="20" y2="19"></line>
        </svg>
        <div class="flex flex-col gap-1.5">
          <h3 class="font-sora text-[20px] font-semibold text-black">Software Development</h3>
          <p class="font-dm text-[13px] text-[#888888]">Python, JavaScript, functional programming</p>
        </div>
      </div>

      <!-- 3D Printing + Woodworking -->
      <div class="flex flex-col justify-between p-7 h-[200px] bg-black">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="28"
          height="28"
          viewBox="0 0 24 24"
          fill="none"
          stroke="white"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path
            d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"
          ></path>
          <polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline>
          <line x1="12" y1="22.08" x2="12" y2="12"></line>
        </svg>
        <div class="flex flex-col gap-1.5">
          <h3 class="font-sora text-[20px] font-semibold text-white">3D Printing + Woodworking</h3>
          <p class="font-dm text-[13px] text-[#888888]">Maker projects and physical crafts</p>
        </div>
      </div>

      <!-- DevOps & Architecture -->
      <div class="flex flex-col justify-between p-7 h-[200px] bg-white border border-[#F0F0F0]">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="28"
          height="28"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <rect x="2" y="2" width="20" height="8" rx="2" ry="2"></rect>
          <rect x="2" y="14" width="20" height="8" rx="2" ry="2"></rect>
          <line x1="6" y1="6" x2="6.01" y2="6"></line>
          <line x1="6" y1="18" x2="6.01" y2="18"></line>
        </svg>
        <div class="flex flex-col gap-1.5">
          <h3 class="font-sora text-[20px] font-semibold text-black">DevOps &amp; Architecture</h3>
          <p class="font-dm text-[13px] text-[#888888]">Infrastructure, CI/CD, system design</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Articles -->
  <section class="bg-white p-20 flex flex-col gap-12">
    <div class="flex items-end justify-between w-full">
      <div class="flex flex-col gap-2">
        <h2 class="font-sora text-5xl font-semibold text-black">Latest Articles</h2>
        <p class="font-dm text-[15px] text-[#888888]">
          Thoughts on engineering, building products, and making things.
        </p>
      </div>
      <a
        href={`${base}articles`}
        class="flex items-center gap-2 font-dm text-sm font-medium text-black"
      >
        View all articles
        <span>→</span>
      </a>
    </div>
    <div class="grid grid-cols-3 gap-6 w-full">
      {
        latestArticles.map((article) => (
          <a href={`${base}articles/${toSlug(article.id)}`} class="flex flex-col group">
            {article.data.image && (
              <div class="h-[240px] overflow-hidden">
                <img
                  src={article.data.image}
                  alt={article.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
              </div>
            )}
            <div class="flex flex-col gap-3 pt-6">
              <span class="font-dm text-[11px] font-medium text-[#AAAAAA] tracking-[2px] uppercase">
                {article.data.category}
              </span>
              <h3 class="font-sora text-[22px] font-semibold leading-[1.3] text-black">
                {article.data.title}
              </h3>
              <span class="font-dm text-xs text-[#AAAAAA]">
                {formatDate(article.data.date)} &nbsp;•&nbsp; {article.data.readTime}
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <!-- Experience -->
  <section class="bg-black p-20 flex flex-col gap-14">
    <div class="flex flex-col gap-3">
      <h2 class="font-sora text-5xl font-semibold text-white">Experience</h2>
      <p class="font-dm text-[15px] text-[#666666]">Years of building real products for real users.</p>
    </div>
    <div class="grid grid-cols-4 w-full">
      {
        [
          { num: '7+', label: 'Years of experience' },
          { num: '5+', label: 'Industries served' },
          { num: '20+', label: 'Projects delivered' },
          { num: '3', label: 'Countries worked in' },
        ].map(({ num, label }) => (
          <div class="flex flex-col gap-2">
            <span class="font-sora text-[64px] font-bold text-white leading-none">{num}</span>
            <span class="font-dm text-sm text-[#666666] mt-2">{label}</span>
          </div>
        ))
      }
    </div>
    <div class="flex flex-col gap-6 w-full">
      <span class="font-dm text-[11px] font-medium text-[#666666] tracking-[3px] uppercase">
        Tech Stack
      </span>
      <div class="h-px bg-[#222222] w-full"></div>
      <div class="flex items-center gap-8 flex-wrap">
        {
          [
            'Python',
            'JavaScript',
            'React',
            'Node.js',
            'Docker',
            'AWS',
            'PostgreSQL',
            'Terraform',
            'Linux',
            'Git',
          ].map((tech) => (
            <span class="font-dm text-sm text-white">{tech}</span>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section id="contact" class="bg-[#F5F5F5] p-20 flex flex-col items-center gap-8">
    <h2 class="font-sora text-5xl font-semibold text-black text-center">
      Let's build something together.
    </h2>
    <p class="font-dm text-base text-[#888888] text-center max-w-[560px]">
      Open to collaborations, consulting, and interesting conversations.
    </p>
    <a
      href="mailto:hello@abelorihuela.dev"
      class="bg-black text-white font-dm text-sm font-medium px-10 py-4 inline-block"
    >
      Send me an email
    </a>
  </section>

  <Footer />
</Layout>
